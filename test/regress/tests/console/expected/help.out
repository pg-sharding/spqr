HELP CREATE KEY RANGE;
                                       help                                       
----------------------------------------------------------------------------------
 NAME                                                                            +
     CREATE KEY RANGE - This command is used to create a new key range. Since the+
     key space is an ordered set,                                                +
                                                                                 +
 SYNTAX                                                                          +
     CREATE KEY RANGE [ <keyRangeID> ]                                           +
       FROM <lowerBound>                                                         +
       ROUTE TO <shardID>                                                        +
       FOR DISTRIBUTION <distributionID>                                         +
                                                                                 +
     where lowerBound is a single value or comma-separated values                +
     for composite keys (e.g., "100, 'value'" for a two-column key)              +
                                                                                 +
 DESCRIPTION                                                                     +
     This command is used to create a new key range. Since the key space is an   +
     ordered set,                                                                +
     it is enough to specify only one end of the range.                          +
                                                                                 +
     For composite sharding keys, specify multiple values separated by commas    +
     that correspond                                                             +
     to each column in the distribution.                                         +
                                                                                 +
 PARAMETERS                                                                      +
     <keyRangeID> - Unique identifier for the key range (optional, auto-generated+
         if omitted)                                                             +
     <lowerBound> - Lower boundary value (inclusive). Can be integer, string, or +
         comma-separated values for composite keys                               +
     <shardID> - Target shard ID where data in this range is stored              +
     <distributionID> - Distribution ID this key range belongs to                +
                                                                                 +
 EXAMPLES                                                                        +
     Single column key range:                                                    +
         CREATE KEY RANGE krid1 FROM 1000 ROUTE TO shard1 FOR DISTRIBUTION ds1;  +
     Composite key range with two integers:                                      +
         CREATE KEY RANGE krid2 FROM 0, 100 ROUTE TO shard2 FOR DISTRIBUTION ds2;+
     Composite key range with integer and varchar:                               +
         CREATE KEY RANGE krid3 FROM 100, 'aaaaa'                                +
             ROUTE TO shard3 FOR DISTRIBUTION ds3;                               +
                                                                                 +
 TIPS                                                                            +
     - Value bounds should be continuous and non-overlapping                     +
     - Use SHOW KEY RANGES to list existing ranges                               +
     - Lock key ranges during maintenance operations with LOCK KEY RANGE         +
     - Key ranges are immutable once created; use SPLIT or UNITE for             +
       modifications                                                             +
     - Consider boundary values carefully to distribute data evenly              +
                                                                                 +
 RELATED COMMANDS                                                                +
     SHOW KEY RANGES                                                             +
     LOCK KEY RANGE                                                              +
     UNLOCK KEY RANGE                                                            +
     SPLIT KEY RANGE                                                             +
     UNITE KEY RANGE                                                             +
     DROP KEY RANGE
(1 row)

HELP DROP KEY RANGE;
                                      help                                       
---------------------------------------------------------------------------------
 NAME                                                                           +
     DROP KEY RANGE - Removes a key range from the cluster. This deletes the key+
     range metadata                                                             +
                                                                                +
 SYNTAX                                                                         +
     DROP KEY RANGE <keyRangeID>                                                +
     DROP KEY RANGE ALL                                                         +
                                                                                +
 DESCRIPTION                                                                    +
     Removes a key range from the cluster. This deletes the key range metadata  +
     but does not affect the actual data stored on the shard.                   +
                                                                                +
     Use DROP KEY RANGE ALL to remove all key ranges at once.                   +
                                                                                +
 PARAMETERS                                                                     +
     <keyRangeID> - Identifier of the key range to drop                         +
     <ALL> - Special keyword to drop all key ranges                             +
                                                                                +
 EXAMPLES                                                                       +
     Drop a specific key range:                                                 +
         DROP KEY RANGE krid1;                                                  +
     Drop all key ranges:                                                       +
         DROP KEY RANGE ALL;                                                    +
                                                                                +
 TIPS                                                                           +
     - Dropping a key range does not migrate or delete the underlying data      +
     - Use SHOW KEY RANGES to verify which key ranges exist before dropping     +
     - Consider the impact on routing before dropping key ranges in production  +
                                                                                +
 RELATED COMMANDS                                                               +
     CREATE KEY RANGE                                                           +
     SHOW KEY RANGES                                                            +
     MOVE KEY RANGE
(1 row)

HELP LOCK KEY RANGE;
                                       help                                       
----------------------------------------------------------------------------------
 NAME                                                                            +
     LOCK KEY RANGE - Locks a key range to prevent concurrent modifications. This+
     is typically                                                                +
                                                                                 +
 SYNTAX                                                                          +
     LOCK KEY RANGE <keyRangeID>                                                 +
                                                                                 +
 DESCRIPTION                                                                     +
     Locks a key range to prevent concurrent modifications. This is typically    +
     used before performing operations like SPLIT or UNITE that require          +
     exclusive access to the key range.                                          +
                                                                                 +
     While a key range is locked, queries routed to it will receive a            +
     `key range is locked` error.                                                +
                                                                                 +
 PARAMETERS                                                                      +
     <keyRangeID> - Identifier of the key range to lock                          +
                                                                                 +
 TIPS                                                                            +
     - Always pair LOCK with UNLOCK to avoid failing queries indefinitely        +
     - Use SHOW key_ranges to check the current lock status                      +
                                                                                 +
 RELATED COMMANDS                                                                +
     UNLOCK KEY RANGE                                                            +
     SPLIT KEY RANGE                                                             +
     UNITE KEY RANGE                                                             +
     SHOW KEY RANGES
(1 row)

HELP UNLOCK KEY RANGE;
                                     help                                      
-------------------------------------------------------------------------------
 NAME                                                                         +
     UNLOCK KEY RANGE - Releases the lock on a key range that was previously  +
     locked with LOCK KEY RANGE.                                              +
                                                                              +
 SYNTAX                                                                       +
     UNLOCK KEY RANGE <keyRangeID>                                            +
                                                                              +
 DESCRIPTION                                                                  +
     Releases the lock on a key range that was previously locked with LOCK KEY+
     RANGE.                                                                   +
     After unlocking, queries routed to this key range will resume normal     +
     processing.                                                              +
                                                                              +
 PARAMETERS                                                                   +
     <keyRangeID> - Identifier of the key range to unlock                     +
                                                                              +
 TIPS                                                                         +
     - Always unlock key ranges after completing maintenance operations       +
     - Forgetting to unlock will cause queries routed to the key range to fail+
       with an error                                                          +
                                                                              +
 RELATED COMMANDS                                                             +
     LOCK KEY RANGE                                                           +
     SPLIT KEY RANGE                                                          +
     UNITE KEY RANGE                                                          +
     SHOW KEY RANGES
(1 row)

HELP SPLIT KEY RANGE;
                                       help                                       
----------------------------------------------------------------------------------
 NAME                                                                            +
     SPLIT KEY RANGE - Splits an existing key range into two key ranges at the   +
     specified boundary value.                                                   +
                                                                                 +
 SYNTAX                                                                          +
     SPLIT KEY RANGE <newKeyRangeID> FROM <sourceKeyRangeID> BY <splitBound>     +
                                                                                 +
     where splitBound is a single value or comma-separated values                +
     for composite keys                                                          +
                                                                                 +
 DESCRIPTION                                                                     +
     Splits an existing key range into two key ranges at the specified boundary  +
     value.                                                                      +
     The new key range takes the upper portion of the original range (from the   +
     split                                                                       +
     point to the original upper bound), while the source range keeps the lower  +
     portion.                                                                    +
                                                                                 +
     Both resulting key ranges remain on the same shard. Use REDISTRIBUTE KEY    +
     RANGE                                                                       +
     afterwards to relocate one of them if needed.                               +
                                                                                 +
 PARAMETERS                                                                      +
     <newKeyRangeID> - Identifier for the newly created key range (upper portion)+
     <sourceKeyRangeID> - Identifier of the existing key range to split          +
     <splitBound> - Boundary value where the split occurs. Can be integer,       +
         string, or comma-separated values for composite keys                    +
                                                                                 +
 EXAMPLES                                                                        +
     Split a key range at integer boundary:                                      +
         SPLIT KEY RANGE krid2 FROM krid1 BY 100;                                +
     Split a key range at UUID boundary:                                         +
         SPLIT KEY RANGE krid4 FROM krid3                                        +
             BY 'FF000000-0000-0000-0000-000000000000';                          +
                                                                                 +
 TIPS                                                                            +
     - Lock the source key range before splitting to prevent concurrent          +
       modifications                                                             +
     - The split bound must fall within the source key range boundaries          +
     - After splitting, use MOVE KEY RANGE to relocate a range to another shard  +
     - Use UNITE KEY RANGE to reverse a split operation                          +
                                                                                 +
 RELATED COMMANDS                                                                +
     LOCK KEY RANGE                                                              +
     UNLOCK KEY RANGE                                                            +
     UNITE KEY RANGE                                                             +
     MOVE KEY RANGE                                                              +
     CREATE KEY RANGE
(1 row)

HELP MOVE KEY RANGE;
                                      help                                       
---------------------------------------------------------------------------------
 NAME                                                                           +
     MOVE KEY RANGE - Updates the routing metadata to assign a key range to a   +
     different shard.                                                           +
                                                                                +
 SYNTAX                                                                         +
     MOVE KEY RANGE <keyRangeID> TO <shardID>                                   +
                                                                                +
 DESCRIPTION                                                                    +
     Updates the routing metadata to assign a key range to a different shard.   +
     This only changes where new queries for this key range are routed — it does+
     NOT                                                                        +
     migrate the actual data between shards.                                    +
                                                                                +
 WARNINGS                                                                       +
     - MOVE KEY RANGE only updates metadata. To move both metadata and data, use+
       REDISTRIBUTE KEY RANGE instead.                                          +
                                                                                +
 PARAMETERS                                                                     +
     <keyRangeID> - Identifier of the key range to move                         +
     <shardID> - Target shard ID to route this key range to                     +
                                                                                +
 EXAMPLES                                                                       +
     Move a key range to a different shard:                                     +
         MOVE KEY RANGE krid1 TO sh2;                                           +
                                                                                +
 TIPS                                                                           +
     - Use this command when data has already been migrated externally          +
     - For a complete migration including data, use REDISTRIBUTE KEY RANGE      +
     - Verify the target shard exists with SHOW SHARDS before moving            +
                                                                                +
 RELATED COMMANDS                                                               +
     REDISTRIBUTE KEY RANGE                                                     +
     SHOW KEY RANGES                                                            +
     CREATE KEY RANGE                                                           +
     DROP KEY RANGE
(1 row)

HELP UNITE KEY RANGE;
                                       help                                       
----------------------------------------------------------------------------------
 NAME                                                                            +
     UNITE KEY RANGE - Merges two adjacent key ranges into a single key range.   +
     The left key range absorbs                                                  +
                                                                                 +
 SYNTAX                                                                          +
     UNITE KEY RANGE <leftKeyRangeID> WITH <rightKeyRangeID>                     +
                                                                                 +
 DESCRIPTION                                                                     +
     Merges two adjacent key ranges into a single key range. The left key range  +
     absorbs                                                                     +
     the right key range, extending its upper bound to cover both ranges.        +
                                                                                 +
     The two key ranges must be adjacent (share a boundary) and must route to the+
     same shard.                                                                 +
     After the operation, the right key range is removed.                        +
                                                                                 +
 PARAMETERS                                                                      +
     <leftKeyRangeID> - Identifier of the left (lower) key range that will absorb+
         the other                                                               +
     <rightKeyRangeID> - Identifier of the right (upper) key range that will be  +
         merged into the left                                                    +
                                                                                 +
 EXAMPLES                                                                        +
     Unite two adjacent key ranges:                                              +
         UNITE KEY RANGE krid1 WITH krid2;                                       +
                                                                                 +
 TIPS                                                                            +
     - Both key ranges must be adjacent and on the same shard                    +
     - The right key range is removed after the operation                        +
     - Lock both key ranges before uniting to prevent concurrent modifications   +
     - This is the inverse operation of SPLIT KEY RANGE                          +
                                                                                 +
 RELATED COMMANDS                                                                +
     SPLIT KEY RANGE                                                             +
     LOCK KEY RANGE                                                              +
     UNLOCK KEY RANGE                                                            +
     SHOW KEY RANGES                                                             +
     DROP KEY RANGE
(1 row)

HELP REDISTRIBUTE KEY RANGE;
                                       help                                       
----------------------------------------------------------------------------------
 NAME                                                                            +
     REDISTRIBUTE KEY RANGE - Moves a key range to a different shard, including  +
     the actual data migration.                                                  +
                                                                                 +
 SYNTAX                                                                          +
     REDISTRIBUTE KEY RANGE <keyRangeID> TO <shardID>                            +
       [BATCH SIZE <batchSize>]                                                  +
       [TASK GROUP <taskGroupID>]                                                +
       [CHECK | APPLY | NOWAIT]                                                  +
                                                                                 +
 DESCRIPTION                                                                     +
     Moves a key range to a different shard, including the actual data migration.+
                                                                                 +
     The operation can be run in check-only mode to validate before applying, and+
     supports batch processing to control the migration pace.                    +
                                                                                 +
 WARNINGS                                                                        +
     - This command is not available for installations without SPQR coordinator. +
                                                                                 +
 PARAMETERS                                                                      +
     <keyRangeID> - Identifier of the key range to redistribute                  +
     <shardID> - Target shard ID to migrate data to                              +
     <batchSize> - Number of rows to migrate per batch (optional, default 500)   +
     <taskGroupID> - Task group identifier for tracking the operation (optional) +
     <CHECK> - Only validate the redistribution without applying changes         +
     <APPLY> - Validate and apply the redistribution (default behavior)          +
     <NOWAIT> - Start the redistribution and return immediately without waiting  +
         for completion                                                          +
                                                                                 +
 EXAMPLES                                                                        +
     Redistribute with default settings:                                         +
         REDISTRIBUTE KEY RANGE krid1 TO sh2;                                    +
     Redistribute with custom batch size:                                        +
         REDISTRIBUTE KEY RANGE krid1 TO sh2 BATCH SIZE 100;                     +
     Check redistribution without applying:                                      +
         REDISTRIBUTE KEY RANGE krid1 TO sh2 CHECK;                              +
     Non-blocking redistribution:                                                +
         REDISTRIBUTE KEY RANGE krid1 TO sh2 BATCH SIZE 500 NOWAIT;              +
     Redistribute with task group for tracking:                                  +
         REDISTRIBUTE KEY RANGE krid1 TO sh2 TASK GROUP taskgroup1;              +
                                                                                 +
 TIPS                                                                            +
     - Use CHECK mode first to validate before applying in production            +
     - Adjust BATCH SIZE to balance migration speed vs. cluster load             +
     - Use NOWAIT for large migrations and monitor progress with SHOW task_group +
     - For metadata-only changes (when data is already on the target), use MOVE  +
       KEY RANGE instead                                                         +
                                                                                 +
 RELATED COMMANDS                                                                +
     MOVE KEY RANGE                                                              +
     SHOW KEY RANGES                                                             +
     CREATE KEY RANGE                                                            +
     SPLIT KEY RANGE
(1 row)

HELP SHOW;
                                       help                                       
----------------------------------------------------------------------------------
 NAME                                                                            +
     SHOW - Displays cluster metadata, topology, configuration, and runtime      +
     status.                                                                     +
                                                                                 +
 SYNTAX                                                                          +
     SHOW <target> [(<columns>)]                                                 +
       [WHERE <condition>]                                                       +
       [GROUP BY <column>]                                                       +
       [ORDER BY <column> [ASC|DESC]]                                            +
                                                                                 +
 DESCRIPTION                                                                     +
     Displays cluster metadata, topology, configuration, and runtime status.     +
                                                                                 +
     Valid targets: `databases`, `routers`, `shards`, `distributions`,           +
     `key_ranges`,                                                               +
     `key_ranges_extended`, `relations`, `reference_relations`, `pools`,         +
     `clients`,                                                                  +
     `backend_connections`, `hosts`, `version`, `status`, `instance`,            +
     `sequences`,                                                                +
     `users`, `task_group`, `task_groups`, `task_group_ext`, `task_groups_ext`,  +
     `move_task`, `move_tasks`, `redistribute_tasks`, `prepared_statements`,     +
     `time_quantiles`, `unique_indexes`, `coordinator_address`, `is_read_only`,  +
     `move_stats`, `errors`, `startup_finished`, `two_phase_tx`, `dcs_storage`,  +
     `file_settings`, `tsa_cache`.                                               +
                                                                                 +
 PARAMETERS                                                                      +
     <target> - The metadata category to display (e.g., databases, shards,       +
         key_ranges, distributions)                                              +
     <columns> - Optional column projection to display only specific fields      +
         (e.g., "(id, status)")                                                  +
     <WHERE condition> - Optional filter to restrict rows by column values (e.g.,+
         WHERE id = 'shard1')                                                    +
     <GROUP BY column> - Optional grouping by a column                           +
     <ORDER BY column> - Optional sorting by a column, with optional ASC or DESC +
         direction                                                               +
                                                                                 +
 EXAMPLES                                                                        +
     Show all shards:                                                            +
         SHOW shards;                                                            +
     Show key ranges with specific columns:                                      +
         SHOW key_ranges (key_range_id, shard_id);                               +
     Show backend connections filtered by hostname:                              +
         SHOW backend_connections WHERE hostname = 'localhost';                  +
     Show clients ordered by user:                                               +
         SHOW clients ORDER BY user DESC;                                        +
     Show backend connections grouped by shard:                                  +
         SHOW backend_connections GROUP BY shard_key_name;                       +
                                                                                 +
 TIPS                                                                            +
     - Use column projection to reduce output to only the fields you need        +
     - Combine WHERE and ORDER BY for targeted diagnostics                       +
     - Use key_ranges_extended for additional detail including shard names       +
     - Use task_group_ext / task_groups_ext for extended task group information  +
                                                                                 +
 RELATED COMMANDS                                                                +
     CREATE KEY RANGE                                                            +
     CREATE DISTRIBUTION                                                         +
     REDISTRIBUTE KEY RANGE
(1 row)

HELP CREATE DISTRIBUTION;
                                      help                                       
---------------------------------------------------------------------------------
 NAME                                                                           +
     CREATE DISTRIBUTION - Creates a sharding distribution with a distribution  +
     identifier and key column types.                                           +
                                                                                +
 SYNTAX                                                                         +
     CREATE DISTRIBUTION <distributionID>                                       +
       [COLUMN TYPES <types> | (<types>)]                                       +
       [DEFAULT SHARD <shardID>]                                                +
                                                                                +
     where types is a comma-separated list of column types for the              +
     distribution key, and each type is one of: INTEGER, INT,                   +
     VARCHAR, UUID (VARCHAR/INTEGER may be followed by HASH)                    +
                                                                                +
     where <shardID> is a default shard identifier. The <shardID> must exist.   +
                                                                                +
 DESCRIPTION                                                                    +
     Creates a sharding distribution with a distribution identifier and key     +
     column types.                                                              +
                                                                                +
     A distribution defines the sharding key type layout used by attached       +
     relations and key ranges.                                                  +
     Optionally, specify a default shard to route records that do not match any +
     key range.                                                                 +
                                                                                +
     For composite sharding keys (multiple columns), specify multiple types     +
     separated by commas.                                                       +
     You can append "hash" after a column type to apply hash-based distribution +
     to that column.                                                            +
                                                                                +
 PARAMETERS                                                                     +
     <distributionID> - Unique identifier of the distribution                   +
     <types> - Distribution key column types in order (single or composite key) +
     <shardID> - Optional default shard identifier for unmatched routing cases  +
                                                                                +
 EXAMPLES                                                                       +
     Single integer key distribution:                                           +
         CREATE DISTRIBUTION ds1 COLUMN TYPES integer;                          +
     Single varchar key distribution with hash:                                 +
         CREATE DISTRIBUTION ds2 COLUMN TYPES varchar hash;                     +
     Composite key distribution with two columns:                               +
         CREATE DISTRIBUTION ds3 COLUMN TYPES integer, integer;                 +
     Composite key with mixed types and hash on second column:                  +
         CREATE DISTRIBUTION ds4 COLUMN TYPES integer, varchar hash;            +
     Parenthesized type syntax with default shard:                              +
         CREATE DISTRIBUTION ds5 (integer, varchar hash) DEFAULT SHARD sh1;     +
                                                                                +
 TIPS                                                                           +
     - Keep column type order aligned with relation distribution keys           +
     - Use hashed types for high-cardinality string/integer keys when needed    +
     - Configure DEFAULT SHARD only when fallback routing is explicitly required+
                                                                                +
 RELATED COMMANDS                                                               +
     ALTER DISTRIBUTION                                                         +
     DROP DISTRIBUTION                                                          +
     CREATE KEY RANGE                                                           +
     SHOW
(1 row)

HELP DROP DISTRIBUTION;
                                      help                                      
--------------------------------------------------------------------------------
 NAME                                                                          +
     DROP DISTRIBUTION - Removes a distribution from cluster metadata.         +
                                                                               +
 SYNTAX                                                                        +
     DROP DISTRIBUTION <distributionID> [CASCADE]                              +
                                                                               +
 DESCRIPTION                                                                   +
     Removes a distribution from cluster metadata.                             +
                                                                               +
     Use CASCADE to remove dependent metadata objects (key ranges, attached    +
     relations) when required.                                                 +
                                                                               +
 WARNINGS                                                                      +
     - Dropping a distribution removes routing metadata and may impact attached+
       relations.                                                              +
                                                                               +
 PARAMETERS                                                                    +
     <distributionID> - Identifier of the distribution to drop                 +
     <CASCADE> - Also remove dependent metadata objects                        +
                                                                               +
 EXAMPLES                                                                      +
     Drop one distribution:                                                    +
         DROP DISTRIBUTION ds1;                                                +
     Drop distribution with dependent metadata:                                +
         DROP DISTRIBUTION ds1 CASCADE;                                        +
                                                                               +
 TIPS                                                                          +
     - Check current distributions and dependencies with SHOW before dropping  +
                                                                               +
 RELATED COMMANDS                                                              +
     CREATE DISTRIBUTION                                                       +
     ALTER DISTRIBUTION                                                        +
     SHOW
(1 row)

HELP ALTER DISTRIBUTION;
                                       help                                       
----------------------------------------------------------------------------------
 NAME                                                                            +
     ALTER DISTRIBUTION - Modifies distribution metadata.                        +
                                                                                 +
 SYNTAX                                                                          +
     ALTER DISTRIBUTION <distributionID> ATTACH RELATION <relationName>          +
       DISTRIBUTION KEY <keys> [HASH FUNCTION <hashFunction>]                    +
     ALTER DISTRIBUTION <distributionID> DETACH RELATION <relationName>          +
     ALTER DISTRIBUTION <distributionID> ALTER RELATION <relationName>           +
       DISTRIBUTION KEY <keys> [HASH FUNCTION <hashFunction>]                    +
     ALTER DISTRIBUTION <distributionID> ALTER RELATION <relationName>           +
       SCHEMA <schemaName>                                                       +
     ALTER DISTRIBUTION <distributionID> ALTER RELATION <relationName>           +
       RENAME DISTRIBUTION COLUMN <oldColumnName> TO <newColumnName>             +
     ALTER DISTRIBUTION <distributionID> ADD DEFAULT SHARD <shardID>             +
     ALTER DISTRIBUTION <distributionID> DROP DEFAULT SHARD                      +
                                                                                 +
     where keys is a comma-separated list of column names (e.g., "col1, col2")   +
     where hashFunction is one of: IDENTITY, MURMUR, CITY                        +
                                                                                 +
 DESCRIPTION                                                                     +
     Modifies distribution metadata.                                             +
                                                                                 +
     Covers relation attachments, distribution key metadata, schema metadata,    +
     and default shard settings. This command operates on SPQR metadata and does +
     not execute table DDL on shards.                                            +
                                                                                 +
     ATTACH RELATION attaches one or more relations to the distribution with a   +
     specified distribution key. For composite sharding keys, specify multiple   +
     column names separated by commas in the DISTRIBUTION KEY clause.            +
                                                                                 +
     DETACH RELATION detaches a relation from the distribution.                  +
                                                                                 +
     ALTER RELATION DISTRIBUTION KEY replaces the entire distribution key of an  +
     already attached relation. This overwrites all column names and hash        +
     functions                                                                   +
     in one shot — it does not patch individual columns. Use this when you need  +
     to                                                                          +
     change the key structure entirely, or to fix expression-based routing       +
     entries                                                                     +
     (which RENAME DISTRIBUTION COLUMN does not support). The new key must have  +
     the                                                                         +
     same number of entries as the distribution's column types.                  +
                                                                                 +
     ALTER RELATION SCHEMA changes the schema associated with an attached        +
     relation                                                                    +
     in the distribution metadata.                                               +
                                                                                 +
     RENAME DISTRIBUTION COLUMN is a metadata-only fix that renames a column in  +
     the                                                                         +
     distribution key of an attached relation. It does not execute ALTER TABLE   +
     RENAME                                                                      +
     COLUMN on PostgreSQL — it only updates the column name stored in SPQR       +
     metadata.                                                                   +
     The primary use case is fixing a case mismatch between the column name in   +
     SPQR                                                                        +
     metadata and the actual PostgreSQL column. For composite keys, call this    +
     command                                                                     +
     once per column that needs renaming.                                        +
                                                                                 +
     ADD DEFAULT SHARD sets a default shard for the distribution, routing records+
     that                                                                        +
     do not match any key range. DROP DEFAULT SHARD removes the default shard    +
     setting.                                                                    +
                                                                                 +
 WARNINGS                                                                        +
     - ALTER RELATION operations are metadata changes and may affect routing     +
       immediately.                                                              +
     - Use maintenance windows for key/schema metadata changes in write-heavy    +
       workloads.                                                                +
                                                                                 +
 PARAMETERS                                                                      +
     <distributionID> - Identifier of the distribution to modify                 +
     <relationName> - Relation to attach, detach, or alter                       +
     <keys> - Distribution key definition (column list and optional hash         +
         functions)                                                              +
     <hashFunction> - Hash function to apply to the key (IDENTITY, MURMUR, or    +
         CITY)                                                                   +
     <schemaName> - Schema metadata value for an attached relation               +
     <oldColumnName> - Existing distribution key column name in metadata         +
     <newColumnName> - New distribution key column name in metadata              +
     <shardID> - Shard identifier to set as default shard                        +
                                                                                 +
 EXAMPLES                                                                        +
     Attach relation with single distribution key:                               +
         ALTER DISTRIBUTION ds1 ATTACH RELATION orders DISTRIBUTION KEY order_id;+
     Attach relation with composite key and hash function:                       +
         ALTER DISTRIBUTION ds2 ATTACH RELATION users                            +
             DISTRIBUTION KEY tenant_id, user_id HASH FUNCTION MURMUR;           +
     Detach relation:                                                            +
         ALTER DISTRIBUTION ds1 DETACH RELATION orders;                          +
     Replace relation distribution key:                                          +
         ALTER DISTRIBUTION ds1 ALTER RELATION orders                            +
             DISTRIBUTION KEY customer_id;                                       +
     Change relation schema:                                                     +
         ALTER DISTRIBUTION ds1 ALTER RELATION orders SCHEMA my_schema;          +
     Fix column name casing in metadata (w_id vs W_ID):                          +
         ALTER DISTRIBUTION ds1 ALTER RELATION rc_test                           +
             RENAME DISTRIBUTION COLUMN W_ID TO w_id;                            +
     Set default shard:                                                          +
         ALTER DISTRIBUTION ds1 ADD DEFAULT SHARD sh1;                           +
     Remove default shard:                                                       +
         ALTER DISTRIBUTION ds1 DROP DEFAULT SHARD;                              +
                                                                                 +
 SUBCOMMANDS                                                                     +
     ALTER DISTRIBUTION ATTACH RELATION                                          +
     CREATE RELATION                                                             +
     ALTER DISTRIBUTION DETACH RELATION                                          +
     ALTER DISTRIBUTION ALTER RELATION DISTRIBUTION KEY                          +
     ALTER DISTRIBUTION ALTER RELATION SCHEMA                                    +
     ALTER DISTRIBUTION RENAME DISTRIBUTION COLUMN                               +
     ALTER DISTRIBUTION ADD DEFAULT SHARD                                        +
     ALTER DISTRIBUTION DROP DEFAULT SHARD                                       +
                                                                                 +
 TIPS                                                                            +
     - Use CREATE DISTRIBUTION first, then attach relations and create key ranges+
     - Verify metadata after changes with SHOW relations and SHOW distributions  +
     - Prefer replacing full distribution keys when relation uses                +
       expression-based routing                                                  +
     - For composite keys, call RENAME DISTRIBUTION COLUMN once per column that  +
       needs renaming                                                            +
                                                                                 +
 RELATED COMMANDS                                                                +
     CREATE DISTRIBUTION                                                         +
     DROP DISTRIBUTION                                                           +
     CREATE KEY RANGE                                                            +
     SHOW
(1 row)

HELP ALTER DISTRIBUTION ATTACH RELATION;
                                       help                                       
----------------------------------------------------------------------------------
 NAME                                                                            +
     ALTER DISTRIBUTION ATTACH RELATION - Attaches one or more                   +
     [relations](/sharding/sharded_tables) to an existing distribution using the +
     ATTACH RELATION clause.                                                     +
                                                                                 +
 SYNTAX                                                                          +
     ALTER DISTRIBUTION <distributionID> ATTACH RELATION                         +
       <relationName> [, <relationName> ...]                                     +
       DISTRIBUTION KEY <keys> [HASH FUNCTION <hashFunction>]                    +
                                                                                 +
     where keys is a comma-separated list of column names                        +
     (e.g., "col1, col2" for composite keys)                                     +
     where hashFunction is one of: IDENTITY, MURMUR, CITY                        +
                                                                                 +
 DESCRIPTION                                                                     +
     Attaches one or more [relations](/sharding/sharded_tables) to an existing   +
     distribution using the ATTACH RELATION clause.                              +
                                                                                 +
     For composite sharding keys, specify multiple column names separated by     +
     commas in the DISTRIBUTION KEY clause.                                      +
                                                                                 +
 EXAMPLES                                                                        +
     Single column sharding key:                                                 +
         ALTER DISTRIBUTION ds1 ATTACH RELATION orders DISTRIBUTION KEY order_id;+
     Composite sharding key with two columns:                                    +
         ALTER DISTRIBUTION ds2 ATTACH RELATION users                            +
             DISTRIBUTION KEY tenant_id, user_id;                                +
     Composite key with hash function:                                           +
         ALTER DISTRIBUTION ds3 ATTACH RELATION events                           +
             DISTRIBUTION KEY region_id, event_id HASH FUNCTION MURMUR;
(1 row)

HELP CREATE RELATION;
                                       help                                       
----------------------------------------------------------------------------------
 NAME                                                                            +
     CREATE RELATION - This command is a shorthand for [ALTER DISTRIBUTION ATTACH+
     RELATION](#alter-distribution-attach-relation). It creates a relation and   +
     attaches it to a distribution in a single statement.                        +
                                                                                 +
 SYNTAX                                                                          +
     CREATE [DISTRIBUTED] RELATION [schema.]<relation_name> (<keys>)             +
         [IN <distribution_id> | FOR DISTRIBUTION <distribution_id>]             +
                                                                                 +
 DESCRIPTION                                                                     +
     This command is a shorthand for [ALTER DISTRIBUTION ATTACH                  +
     RELATION](#alter-distribution-attach-relation). It creates a relation and   +
     attaches it to a distribution in a single statement.                        +
     The `DISTRIBUTED` keyword is optional and has no effect on the behavior.    +
                                                                                 +
     There are two syntax forms for specifying distribution keys:                +
                                                                                 +
     **Parenthesized syntax** — column names and optional hash functions are     +
     listed inside parentheses:                                                  +
                                                                                 +
 EXAMPLES                                                                        +
     Simple column with no hash function (uses default distribution):            +
         CREATE RELATION r (i);                                                  +
     Column with hash function:                                                  +
         CREATE RELATION r (i HASH MURMUR);                                      +
     Attach to a specific distribution:                                          +
         CREATE RELATION t (id) IN ds1;                                          +
     Using FOR DISTRIBUTION syntax:                                              +
         CREATE DISTRIBUTED RELATION table1 (i HASH MURMUR) FOR DISTRIBUTION ds1;+
     Composite key with multiple columns:                                        +
         CREATE RELATION t3 (id HASH MURMUR, id2 HASH MURMUR) IN ds3;            +
     Routing expression syntax for composite keys with typed columns:            +
         CREATE RELATION tr (MURMUR [id1 INT HASH, id2 VARCHAR HASH]);           +
     Schema-qualified relation name:                                             +
         CREATE DISTRIBUTED RELATION sh1.r (i) IN d;                             +
     DISTRIBUTION KEY syntax:                                                    +
         CREATE DISTRIBUTED RELATION xx DISTRIBUTION KEY                         +
             col1, col2 HASH FUNCTION MURMUR IN ds1;                             +
     Composite key without hash using DISTRIBUTION KEY syntax:                   +
         CREATE DISTRIBUTED RELATION copy_test (id1, id2) IN ds2;                +
                                                                                 +
 NOTES                                                                           +
     - **DISTRIBUTION KEY syntax** — uses explicit `DISTRIBUTION KEY` clause:    +
       `CREATE [DISTRIBUTED] RELATION [schema.]<relation_name> DISTRIBUTION KEY  +
       <keys> [IN <distribution_id> | FOR DISTRIBUTION <distribution_id>]`
(1 row)

HELP REGISTER ROUTER;
                                       help                                       
----------------------------------------------------------------------------------
 NAME                                                                            +
     REGISTER ROUTER - Registers a router with the SPQR coordinator.             +
                                                                                 +
 SYNTAX                                                                          +
     REGISTER ROUTER <routerID> ADDRESS <address>                                +
                                                                                 +
     where <routerID> is a unique identifier for the router                      +
     (unquoted or quoted string)                                                 +
     where <address> is the network address in the format '[host]:port'          +
                                                                                 +
 DESCRIPTION                                                                     +
     Registers a router with the SPQR coordinator.                               +
                                                                                 +
     When a router is registered, the coordinator becomes aware of it and can    +
     manage                                                                      +
     it as part of the cluster. After registration, the coordinator automatically+
     synchronizes metadata (shards, key ranges, distributions) to the router.    +
                                                                                 +
 WARNINGS                                                                        +
     - This command is not available for installations without SPQR coordinator. +
                                                                                 +
 PARAMETERS                                                                      +
     <routerID> - Unique identifier for the router (e.g., r1 or 'my-router')     +
     <address> - Network address of the router in '[host]:port' format (e.g.,    +
         '[localhost]:6432')                                                     +
                                                                                 +
 EXAMPLES                                                                        +
     Register a router on localhost:                                             +
         REGISTER ROUTER r1 ADDRESS '[localhost]:6432';                          +
     Register a router with a custom address:                                    +
         REGISTER ROUTER r2 ADDRESS '[router-host]:7432';                        +
                                                                                 +
 RELATED COMMANDS                                                                +
     UNREGISTER ROUTER                                                           +
     SHOW
(1 row)

HELP UNREGISTER ROUTER;
                                      help                                       
---------------------------------------------------------------------------------
 NAME                                                                           +
     UNREGISTER ROUTER - Unregisters a router from the SPQR coordinator.        +
                                                                                +
 SYNTAX                                                                         +
     UNREGISTER ROUTER <routerID>                                               +
     UNREGISTER ROUTER ALL                                                      +
                                                                                +
     where <routerID> is the identifier of the router to unregister             +
                                                                                +
 DESCRIPTION                                                                    +
     Unregisters a router from the SPQR coordinator.                            +
                                                                                +
     This removes the router from the coordinator's management. Use ALL to      +
     unregister all routers at once.                                            +
                                                                                +
 WARNINGS                                                                       +
     - This command is not available for installations without SPQR coordinator.+
                                                                                +
 PARAMETERS                                                                     +
     <routerID> - The unique identifier of the router to unregister, or ALL to  +
         unregister every router                                                +
                                                                                +
 EXAMPLES                                                                       +
     Unregister a specific router:                                              +
         UNREGISTER ROUTER r1;                                                  +
     Unregister all routers:                                                    +
         UNREGISTER ROUTER ALL;                                                 +
                                                                                +
 RELATED COMMANDS                                                               +
     REGISTER ROUTER                                                            +
     SHOW
(1 row)

HELP CREATE REFERENCE TABLE;
                                      help                                      
--------------------------------------------------------------------------------
 NAME                                                                          +
     CREATE REFERENCE TABLE - Creates a reference table — a table replicated   +
     across all or specific shards.                                            +
                                                                               +
 SYNTAX                                                                        +
     CREATE REFERENCE TABLE <table_name>                                       +
         [AUTO INCREMENT <column> [START <value>], ...]                        +
         [ON <shard_id>, ...]                                                  +
                                                                               +
 DESCRIPTION                                                                   +
     Creates a reference table — a table replicated across all or specific     +
     shards.                                                                   +
                                                                               +
     The optional AUTO INCREMENT clause creates a sequence for the specified   +
     columns.                                                                  +
     If no shards are specified with ON, the table is created on all shards.   +
                                                                               +
 PARAMETERS                                                                    +
     <table_name> - Name of the reference table to create                      +
     <column> - Column name for auto-increment sequence                        +
     <value> - Initial value for the auto-increment sequence (default 0)       +
     <shard_id> - Shard identifiers where the table will be replicated (default+
         all shards)                                                           +
                                                                               +
 EXAMPLES                                                                      +
     Create a reference table on all shards:                                   +
         CREATE REFERENCE TABLE tax_rates;                                     +
     Create on specific shards:                                                +
         CREATE REFERENCE TABLE tax_rates ON sh1, sh2;                         +
     With auto-increment column:                                               +
         CREATE REFERENCE TABLE orders AUTO INCREMENT id;                      +
     With auto-increment starting at a specific value:                         +
         CREATE REFERENCE TABLE orders AUTO INCREMENT id START 1000;           +
                                                                               +
 RELATED COMMANDS                                                              +
     DROP REFERENCE TABLE                                                      +
     ALTER REFERENCE TABLE STORAGE                                             +
     SYNC REFERENCE TABLE                                                      +
     DROP SEQUENCE
(1 row)

HELP DROP REFERENCE TABLE;
                                      help                                       
---------------------------------------------------------------------------------
 NAME                                                                           +
     DROP REFERENCE TABLE - Removes a reference table from SPQR metadata. This  +
     does not drop the actual                                                   +
                                                                                +
 SYNTAX                                                                         +
     DROP REFERENCE TABLE <table_name>                                          +
                                                                                +
 DESCRIPTION                                                                    +
     Removes a reference table from SPQR metadata. This does not drop the actual+
     table from the shards.                                                     +
                                                                                +
 PARAMETERS                                                                     +
     <table_name> - Name of the reference table to drop                         +
                                                                                +
 EXAMPLES                                                                       +
     Drop a reference table:                                                    +
         DROP REFERENCE TABLE tax_rates;                                        +
                                                                                +
 RELATED COMMANDS                                                               +
     CREATE REFERENCE TABLE                                                     +
     ALTER REFERENCE TABLE STORAGE
(1 row)

HELP ALTER REFERENCE TABLE STORAGE;
                                      help                                       
---------------------------------------------------------------------------------
 NAME                                                                           +
     ALTER REFERENCE TABLE STORAGE - Changes the set of shards where a reference+
     table is stored.                                                           +
                                                                                +
 SYNTAX                                                                         +
     ALTER REFERENCE TABLE <table_name> STORAGE TO (<shard_id>, ...)            +
                                                                                +
 DESCRIPTION                                                                    +
     Changes the set of shards where a reference table is stored.               +
                                                                                +
 PARAMETERS                                                                     +
     <table_name> - Name of the reference table to alter                        +
     <shard_id> - New list of shard identifiers for the reference table         +
                                                                                +
 EXAMPLES                                                                       +
     Change storage to three shards:                                            +
         ALTER REFERENCE TABLE tax_rates STORAGE TO (sh1, sh2, sh3);            +
                                                                                +
 RELATED COMMANDS                                                               +
     CREATE REFERENCE TABLE                                                     +
     DROP REFERENCE TABLE
(1 row)

HELP DROP SEQUENCE;
                                   help                                    
---------------------------------------------------------------------------
 NAME                                                                     +
     DROP SEQUENCE - Drops a sequence used for auto-increment columns in  +
     reference tables.                                                    +
                                                                          +
 SYNTAX                                                                   +
     DROP SEQUENCE <sequence_name> [CASCADE]                              +
                                                                          +
 DESCRIPTION                                                              +
     Drops a sequence used for auto-increment columns in reference tables.+
     The optional CASCADE keyword drops dependent objects as well.        +
                                                                          +
 PARAMETERS                                                               +
     <sequence_name> - Name of the sequence to drop                       +
     <CASCADE> - Optional keyword to also drop dependent objects          +
                                                                          +
 EXAMPLES                                                                 +
     Drop a sequence:                                                     +
         DROP SEQUENCE orders_id_seq;                                     +
     Drop a sequence and its dependents:                                  +
         DROP SEQUENCE orders_id_seq CASCADE;                             +
                                                                          +
 RELATED COMMANDS                                                         +
     CREATE REFERENCE TABLE
(1 row)

HELP SYNC REFERENCE TABLE;
                                      help                                       
---------------------------------------------------------------------------------
 NAME                                                                           +
     SYNC REFERENCE TABLE - Synchronizes a reference table to a target shard by +
     copying data from an                                                       +
                                                                                +
 SYNTAX                                                                         +
     SYNC REFERENCE TABLE <table_name> ON <shard_id>                            +
                                                                                +
 DESCRIPTION                                                                    +
     Synchronizes a reference table to a target shard by copying data from an   +
     existing shard that already has the table.                                 +
                                                                                +
     This is useful when adding a new shard to the cluster that needs reference +
     table data, or recovering reference table data on a shard after a failure. +
                                                                                +
 WARNINGS                                                                       +
     - This command is not available for installations without SPQR coordinator.+
                                                                                +
 PARAMETERS                                                                     +
     <table_name> - Name of the reference table to synchronize                  +
     <shard_id> - Identifier of the destination shard where data will be copied +
                                                                                +
 EXAMPLES                                                                       +
     Sync a reference table to a new shard:                                     +
         SYNC REFERENCE TABLE tax_rates ON sh3;                                 +
                                                                                +
 RELATED COMMANDS                                                               +
     CREATE REFERENCE TABLE                                                     +
     ALTER REFERENCE TABLE STORAGE
(1 row)

HELP KILL CLIENT;
                                     help                                     
------------------------------------------------------------------------------
 NAME                                                                        +
     KILL CLIENT - Terminates a specific client connection by its numeric ID.+
                                                                             +
 SYNTAX                                                                      +
     KILL CLIENT <client_id>                                                 +
                                                                             +
 DESCRIPTION                                                                 +
     Terminates a specific client connection by its numeric ID.              +
                                                                             +
     Use SHOW CLIENTS to find client IDs.                                    +
                                                                             +
 PARAMETERS                                                                  +
     <client_id> - Numeric identifier of the client connection to terminate  +
                                                                             +
 EXAMPLES                                                                    +
     Kill a client connection:                                               +
         KILL CLIENT 42;                                                     +
                                                                             +
 RELATED COMMANDS                                                            +
     KILL BACKEND                                                            +
     SHOW
(1 row)

HELP KILL BACKEND;
                                    help                                    
----------------------------------------------------------------------------
 NAME                                                                      +
     KILL BACKEND - Cancels a backend (shard) connection by its numeric ID.+
                                                                           +
 SYNTAX                                                                    +
     KILL BACKEND <backend_id>                                             +
                                                                           +
 DESCRIPTION                                                               +
     Cancels a backend (shard) connection by its numeric ID.               +
                                                                           +
     Use SHOW BACKEND_CONNECTIONS to find backend IDs.                     +
                                                                           +
 PARAMETERS                                                                +
     <backend_id> - Numeric identifier of the backend connection to cancel +
                                                                           +
 EXAMPLES                                                                  +
     Cancel a backend connection:                                          +
         KILL BACKEND 17;                                                  +
                                                                           +
 RELATED COMMANDS                                                          +
     KILL CLIENT                                                           +
     SHOW
(1 row)

HELP INVALIDATE CACHE;
                                      help                                      
--------------------------------------------------------------------------------
 NAME                                                                          +
     INVALIDATE CACHE - Invalidates the router's schema cache, forcing it to be+
     rebuilt on the                                                            +
                                                                               +
 SYNTAX                                                                        +
     INVALIDATE CACHE                                                          +
     INVALIDATE SCHEMA CACHE                                                   +
                                                                               +
 DESCRIPTION                                                                   +
     Invalidates the router's schema cache, forcing it to be rebuilt on the    +
     next query.                                                               +
                                                                               +
 EXAMPLES                                                                      +
     Invalidate the schema cache:                                              +
         INVALIDATE CACHE;                                                     +
                                                                               +
 RELATED COMMANDS                                                              +
     INVALIDATE BACKENDS                                                       +
     INVALIDATE STALE CLIENTS
(1 row)

HELP INVALIDATE BACKENDS;
                                      help                                      
--------------------------------------------------------------------------------
 NAME                                                                          +
     INVALIDATE BACKENDS - Marks all backend connections as stale, causing them+
     to be re-established.                                                     +
                                                                               +
 SYNTAX                                                                        +
     INVALIDATE BACKENDS                                                       +
                                                                               +
 DESCRIPTION                                                                   +
     Marks all backend connections as stale, causing them to be re-established.+
                                                                               +
 EXAMPLES                                                                      +
     Invalidate all backend connections:                                       +
         INVALIDATE BACKENDS;                                                  +
                                                                               +
 RELATED COMMANDS                                                              +
     INVALIDATE CACHE                                                          +
     INVALIDATE STALE CLIENTS
(1 row)

HELP INVALIDATE STALE CLIENTS;
                                      help                                       
---------------------------------------------------------------------------------
 NAME                                                                           +
     INVALIDATE STALE CLIENTS - Identifies clients with dead TCP connections and+
     signals them to close.                                                     +
                                                                                +
 SYNTAX                                                                         +
     INVALIDATE STALE CLIENTS                                                   +
                                                                                +
 DESCRIPTION                                                                    +
     Identifies clients with dead TCP connections and signals them to close.    +
                                                                                +
 EXAMPLES                                                                       +
     Clean up stale client connections:                                         +
         INVALIDATE STALE CLIENTS;                                              +
                                                                                +
 RELATED COMMANDS                                                               +
     INVALIDATE CACHE                                                           +
     INVALIDATE BACKENDS
(1 row)

