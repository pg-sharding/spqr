------------------------
 distribution id -> d
 shard id        -> sh1
(2 rows)

SELECT __spqr__console_execute('CREATE RELATION d_p_exec(i)');
        attach table         
-----------------------------
 relation name   -> d_p_exec
 distribution id -> d
(2 rows)

SELECT __spqr__console_execute('CREATE REFERENCE RELATION ref_p_exec');
   create reference table    
-----------------------------
 table    -> ref_p_exec
 shard id -> sh1,sh2,sh3,sh4
(2 rows)

CREATE TABLE ref_p_exec(i INT);
NOTICE: send query to shard(s) : sh1,sh2,sh3,sh4
NOTICE: send query to shard(s) : sh1,sh2,sh3,sh4
CREATE TABLE d_p_exec(i INT);
NOTICE: send query to shard(s) : sh1,sh2,sh3,sh4
NOTICE: send query to shard(s) : sh1,sh2,sh3,sh4
SET __spqr__engine_v2 TO true;
SET __spqr__commit_strategy TO 1pc;
PREPARE p1 AS INSERT INTO ref_p_exec (i) VALUES (1);
BEGIN;
EXECUTE p1;
NOTICE: send query to shard(s) : sh1,sh2,sh3,sh4
COMMIT;
SELECT __spqr__ctid('ref_p_exec');
NOTICE: send query to shard(s) : sh1,sh2,sh3,sh4
 __spqr__ctid | i 
--------------+---
 shard sh1    | 1
 shard sh2    | 1
 shard sh3    | 1
 shard sh4    | 1
(4 rows)

BEGIN;
EXECUTE p1;
NOTICE: send query to shard(s) : sh1,sh2,sh3,sh4
ROLLBACK;
SELECT __spqr__ctid('ref_p_exec');
NOTICE: send query to shard(s) : sh1,sh2,sh3,sh4
 __spqr__ctid | i 
--------------+---
 shard sh1    | 1
 shard sh2    | 1
 shard sh3    | 1
 shard sh4    | 1
(4 rows)

INSERT INTO d_p_exec(i) VALUES(1);
NOTICE: send query to shard(s) : sh1
PREPARE p5 AS SELECT $1 FROM d_p_exec /* __spqr__execute_on: sh1 */;
EXECUTE p5 ('aaaa');
NOTICE: send query to shard(s) : sh1
