\c regress
-- INSERT fails: router can't match column "w_id" to metadata "W_ID"
INSERT INTO rc_test (w_id, val) VALUES (1, 'row_sh1');
ERROR:  error processing query 'INSERT INTO rc_test (w_id, val) VALUES (1, 'row_sh1');': too complex query to route
-- SELECT scatters to all shards: column mismatch
SELECT * FROM rc_test WHERE w_id = 1;
NOTICE: send query to shard(s) : sh1,sh2,sh3,sh4
ERROR:  relation "rc_test" does not exist
LINE 1: SELECT * FROM rc_test WHERE w_id = 1;
                      ^
-- Fix the metadata: W_ID -> w_id
\c spqr-console
ALTER DISTRIBUTION ds_rc ALTER RELATION rc_test RENAME DISTRIBUTION COLUMN W_ID TO w_id;
   rename distribution column    
---------------------------------
 distribution id -> ds_rc
 relation name   -> rc_test
 renamed column  -> W_ID to w_id
(3 rows)

SHOW relations;
 relation_name | distribution_id |  distribution_key  | schema_name 
---------------+-----------------+--------------------+-------------
 rc_test       | ds_rc           | ("w_id", identity) | public
(1 row)

\c regress
