\c regress
SET __spqr__engine_v2 TO on;
CREATE TABLE xjoin(id int);
NOTICE: send query to shard(s) : sh1,sh2,sh3,sh4
NOTICE: send query to shard(s) : sh1,sh2,sh3,sh4
