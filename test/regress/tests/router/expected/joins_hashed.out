NOTICE: send query to shard(s) : sh1,sh2,sh3,sh4
NOTICE: send query to shard(s) : sh1,sh2,sh3,sh4
CREATE TABLE zjoin(a int, b int);
NOTICE: send query to shard(s) : sh1,sh2,sh3,sh4
NOTICE: send query to shard(s) : sh1,sh2,sh3,sh4
