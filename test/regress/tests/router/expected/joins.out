(1 row)

-- Join condition is distribution key, scatter out
SELECT * FROM xjoin JOIN yjoin on id=w_id ORDER BY id /* __spqr__engine_v2: false  */;
NOTICE: send query to shard(s) : sh1,sh2,sh3,sh4
 id | w_id 
----+------
  1 |    1
 10 |   10
 15 |   15
 25 |   25
