-- no multishard/rewrite
with v (j, i) as (values(1, 10), (1, 9), (1, 8)) select * from v join xjoin t on v.i = t.id;
NOTICE: send query to shard(s) : sh1
 j | i  | id 
---+----+----
 1 | 10 | 10
(1 row)

